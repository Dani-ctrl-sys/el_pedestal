.vscode/
.idea/
*.swp
*.swo
*~

# macOS
.DS_Store

# Windows
Thumbs.db
desktop.ini

# Dependencias externas descargadas localmente
lib/
vendor/

# Archivos de cobertura y análisis estático
*.gcda
*.gcno
*.gcov
callgrind.out.*
valgrind-*.log
